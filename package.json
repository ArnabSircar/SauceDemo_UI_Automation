{
  "name": "saucedemo_ui_automation",
  "version": "1.0.0",
  "description": "Full automation framework for SauceDemo using Playwright JS",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:functional": "playwright test tests/functional/",
    "test:security": "playwright test tests/security/",
    "test:performance": "playwright test tests/performance/",
    "test:regression": "playwright test tests/regression/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean",
    "allure:serve": "allure serve allure-results",
    "allure:pdf": "node scripts/generateAllurePdf.js",
    "codegen": "playwright codegen https://www.saucedemo.com/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.32.2",
    "allure-playwright": "^2.10.0",
    "dotenv": "^16.3.1",
    "pdf-lib": "^1.17.1",
    "winston": "^3.11.0"
  }
}
